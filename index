     17. CONTROLLER-KONTEXT

     Dieser Kontext wird später an jeden Aufgabentyp übergeben.
     ========================================================= */

  function createTaskContext(task) {
    return {
      task,
      taskState: appState.tasks[task.id],

      elements: {
        taskContent: ui.taskContent,
        checkButton: ui.checkTaskButton,
        resetButton: ui.resetTaskButton,
        hintButton: ui.hintButton,
        nextButton: ui.nextTaskButton
      },

      app: {
        getState: () => cloneData(appState),
        getTaskState: () =>
          cloneData(appState.tasks[task.id]),
        setAnswer: (answer) =>
          setTaskAnswer(task.id, answer),
        updateTaskState: (patch, options) =>
          updateTaskState(task.id, patch, options),
        completeSelfCheck: (answer) =>
          completeSelfCheck(task.id, answer),
        showFeedback,
        hideFeedback,
        refreshControls: updateTaskControls,
        save: persistState
      }
    };
  }

  /* =========================================================
     18. CONTROLLER AKTIVIEREN
     ========================================================= */

  function activateTaskController(task) {
    if (typeof activeControllerCleanup === "function") {
      try {
        activeControllerCleanup();
      } catch (error) {
        console.warn(
          "Fehler beim Aufräumen des vorherigen Aufgaben-Controllers.",
          error
        );
      }
    }

    activeController = null;
    activeTaskContext = createTaskContext(task);
    activeControllerCleanup = null;

    const registeredController =
      getTaskController(task);

    if (!registeredController) {
      renderPlaceholderTask(task);
      return;
    }

    try {
      const controllerInstance =
        typeof registeredController.render === "function"
          ? registeredController.render(activeTaskContext)
          : null;

      activeController = {
        ...registeredController,
        ...(isPlainObject(controllerInstance)
          ? controllerInstance
          : {})
      };

      if (
        typeof activeController.cleanup === "function"
      ) {
        activeControllerCleanup =
          activeController.cleanup;
      }
    } catch (error) {
      console.error(
        `Die Aufgabe ${task.id} konnte nicht gerendert werden.`,
        error
      );

      renderPlaceholderTask(task);

      showFeedback({
        type: "error",
        title: "Aufgabe konnte nicht geladen werden",
        message:
          "Beim Aufbau dieser Aufgabe ist ein technischer Fehler aufgetreten."
      });
    }
  }

  /* =========================================================
     19. BADGES UND AUFGABENMETADATEN
     ========================================================= */

  function updateTaskBadges(task, taskState) {
    if (task.mode === "self-check") {
      ui.automaticBadge.textContent =
        "Freitext · Selbstkontrolle";

      ui.taskPointsBadge.textContent =
        taskState.status === "completed-self-check"
          ? "Selbstkontrolle durchgeführt"
          : "Ohne Punktwertung";

      return;
    }

    if (task.mode === "exploration") {
      ui.automaticBadge.textContent =
        "Interaktive Lernhilfe";

      ui.taskPointsBadge.textContent =
        taskState.status === "correct"
          ? "Erkundung abgeschlossen"
          : "Ohne Punktwertung";

      return;
    }

    ui.automaticBadge.textContent =
      "Automatisch auswertbar";

    ui.taskPointsBadge.textContent =
      `${taskState.points} von ${task.maxPoints} Punkten`;
  }

  /* =========================================================
     20. DARF ZUR NÄCHSTEN AUFGABE GEWECHSELT WERDEN?
     ========================================================= */

  function canProceedFromCurrentTask() {
    const task = getCurrentTask();
    const taskState = getCurrentTaskState();

    /*
      Solange für eine Aufgabe noch kein Controller existiert,
      bleibt die Navigation zu Testzwecken frei.
    */
    if (!activeController) {
      return true;
    }

    if (
      typeof activeController.canProceed === "function"
    ) {
      try {
        return Boolean(
          activeController.canProceed(activeTaskContext)
        );
      } catch (error) {
        console.warn(
          "Die Freigabeprüfung des Controllers ist fehlgeschlagen.",
          error
        );

        return false;
      }
    }

    if (task.mode === "exploration") {
      return taskState.status !== "unseen";
    }

    return ![
      "unseen",
      "started"
    ].includes(taskState.status);
  }

  /* =========================================================
     21. SCHALTFLÄCHENSTATUS
     ========================================================= */

  function updateTaskControls() {
    const currentTask = getCurrentTask();
    const currentTaskState = getCurrentTaskState();

    ui.previousTaskButton.disabled =
      currentTask.number === 1;

    ui.nextTaskButton.disabled =
      currentTask.number === TASKS.length ||
      !canProceedFromCurrentTask();

    ui.checkTaskButton.disabled =
      !activeController ||
      typeof activeController.check !== "function";

    ui.resetTaskButton.disabled =
      !activeController ||
      typeof activeController.reset !== "function";

    const hasControllerHint =
      activeController &&
      typeof activeController.getHint === "function";

    const hasStaticHint =
      Array.isArray(currentTask.helpLevels) &&
      currentTask.helpLevels.length > 0;

    ui.hintButton.disabled =
      !hasControllerHint && !hasStaticHint;

    ui.attemptCounter.textContent =
      formatAttemptText(currentTaskState);
  }

  /* =========================================================
     22. AUFGABE DARSTELLEN
     ========================================================= */

  function renderCurrentTask({
    focusTask = false
  } = {}) {
    const task = getCurrentTask();
    const taskState = getCurrentTaskState();
    const module = getModuleForTask(task);

    markTaskStarted(task.id);

    appState.lastTaskByModule[module.id] = task.id;
    appState.lastOpenedAt = new Date().toISOString();

    ui.taskNumber.textContent =
      `Modul ${module.number} · Aufgabe ${task.number}`;

    ui.taskTitle.textContent = task.title;

    ui.taskInstruction.innerHTML =
      `<strong>Arbeitsauftrag:</strong> ` +
      escapeHtml(task.instruction);

    updateTaskBadges(task, taskState);

    hideFeedback();
    activateTaskController(task);

    updateProgressDisplay();
    updateModuleNavigation();
    updateTaskControls();

    persistState();

    if (focusTask) {
      ui.mainContent.focus({
        preventScroll: true
      });

      ui.taskCard.scrollIntoView({
        behavior: appState.settings.reducedMotion
          ? "auto"
          : "smooth",
        block: "start"
      });
    }

    document.dispatchEvent(
      new CustomEvent("enzymapp:taskchange", {
        detail: {
          taskId: task.id,
          taskNumber: task.number,
          moduleId: task.moduleId
        }
      })
    );
  }

  function updateInterfaceWithoutRerender() {
    const task = getCurrentTask();
    const taskState = getCurrentTaskState();

    updateTaskBadges(task, taskState);
    updateProgressDisplay();
    updateModuleNavigation();
    updateTaskControls();
  }

  /* =========================================================
     23. FREISCHALTUNG UND NAVIGATION
     ========================================================= */

  function unlockTask(taskNumber) {
    appState.highestUnlockedTask = Math.max(
      appState.highestUnlockedTask,
      clamp(taskNumber, 1, TASKS.length)
    );
  }

  function goToTask(
    taskId,
    {
      force = false,
      focusTask = true
    } = {}
  ) {
    const targetTask = TASKS_BY_ID.get(taskId);

    if (!targetTask) {
      return false;
    }

    if (
      !force &&
      targetTask.number > appState.highestUnlockedTask
    ) {
      showFeedback({
        type: "warning",
        title: "Aufgabe noch nicht freigeschaltet",
        message:
          "Bearbeite zunächst die vorherigen Aufgaben."
      });

      return false;
    }

    appState.currentTaskId = targetTask.id;

    const targetModule =
      getModuleForTask(targetTask);

    appState.lastTaskByModule[targetModule.id] =
      targetTask.id;

    persistState();
    renderCurrentTask({ focusTask });

    return true;
  }

  function goToPreviousTask() {
    const currentTask = getCurrentTask();

    if (currentTask.number <= 1) {
      return;
    }

    const previousTask =
      getTaskByNumber(currentTask.number - 1);

    if (previousTask) {
      goToTask(previousTask.id);
    }
  }

  function goToNextTask() {
    const currentTask = getCurrentTask();

    if (currentTask.number >= TASKS.length) {
      return;
    }

    if (!canProceedFromCurrentTask()) {
      showFeedback({
        type: "warning",
        title: "Aufgabe noch nicht abgeschlossen",
        message:
          "Prüfe oder vervollständige zunächst die aktuelle Aufgabe."
      });

      return;
    }

    const nextTask =
      getTaskByNumber(currentTask.number + 1);

    if (!nextTask) {
      return;
    }

    unlockTask(nextTask.number);
    goToTask(nextTask.id);
  }

  function goToModule(moduleId) {
    const module = MODULES_BY_ID.get(moduleId);

    if (!module) {
      return;
    }

    if (
      module.firstTask > appState.highestUnlockedTask
    ) {
      showFeedback({
        type: "warning",
        title: "Modul noch nicht freigeschaltet",
        message:
          "Bearbeite zunächst die vorherigen Aufgaben."
      });

      return;
    }

    const rememberedTaskId =
      appState.lastTaskByModule[moduleId];

    if (
      rememberedTaskId &&
      TASKS_BY_ID.has(rememberedTaskId) &&
      TASKS_BY_ID.get(rememberedTaskId).number <=
        appState.highestUnlockedTask
    ) {
      goToTask(rememberedTaskId);
      return;
    }

    const firstAccessibleTask = TASKS.find(
      (task) =>
        task.moduleId === moduleId &&
        task.number <= appState.highestUnlockedTask
    );

    if (firstAccessibleTask) {
      goToTask(firstAccessibleTask.id);
    }
  }

  /* =========================================================
     24. AUSWERTUNGSERGEBNIS VERARBEITEN
     ========================================================= */

  function applyEvaluationResult(task, result) {
    const taskState = appState.tasks[task.id];

    const normalizedResult =
      isPlainObject(result) ? result : {};

    const isCorrect =
      normalizedResult.correct === true;

    const isPartial =
      normalizedResult.partial === true;

    const newStatus = isCorrect
      ? "correct"
      : isPartial
        ? "checked-partial"
        : "checked-incorrect";

    const fallbackPoints = isCorrect
      ? task.maxPoints
      : 0;

    taskState.status = newStatus;
    taskState.points = clamp(
      Number.isFinite(normalizedResult.score)
        ? normalizedResult.score
        : fallbackPoints,
      0,
      task.maxPoints
    );

    if (normalizedResult.answer !== undefined) {
      taskState.answer = normalizedResult.answer;
    }

    taskState.lastModified = new Date().toISOString();

    const feedbackType = isCorrect
      ? "success"
      : isPartial
        ? "warning"
        : "error";

    const feedbackTitle =
      normalizedResult.title ??
      (
        isCorrect
          ? "Vollständig korrekt"
          : isPartial
            ? "Teilweise korrekt"
            : "Noch nicht korrekt"
      );

    const feedbackMessage =
      normalizedResult.message ??
      (
        isCorrect
          ? "Die Aufgabe wurde vollständig korrekt gelöst."
          : isPartial
            ? "Ein Teil der Antwort ist korrekt. Prüfe die markierten Bereiche."
            : "Prüfe deine Eingaben und versuche es erneut."
      );

    persistState();
    updateInterfaceWithoutRerender();

    showFeedback({
      type: feedbackType,
      title: feedbackTitle,
      message: feedbackMessage
    });
  }

  /* =========================================================
     25. PRÜFEN
     ========================================================= */

  async function handleCheckTask() {
    if (
      !activeController ||
      typeof activeController.check !== "function"
    ) {
      return;
    }

    const task = getCurrentTask();
    const taskState = getCurrentTaskState();

    taskState.attempts += 1;
    taskState.lastModified = new Date().toISOString();

    ui.checkTaskButton.disabled = true;

    try {
      const result = await activeController.check(
        activeTaskContext
      );

      applyEvaluationResult(task, result);
    } catch (error) {
      console.error(
        `Die Aufgabe ${task.id} konnte nicht geprüft werden.`,
        error
      );

      showFeedback({
        type: "error",
        title: "Prüfung nicht möglich",
        message:
          "Beim Prüfen der Antwort ist ein technischer Fehler aufgetreten."
      });
    } finally {
      updateTaskControls();
    }
  }

  /* =========================================================
     26. AUFGABE ZURÜCKSETZEN
     ========================================================= */

  function handleResetTask() {
    if (
      !activeController ||
      typeof activeController.reset !== "function"
    ) {
      return;
    }

    const taskState = getCurrentTaskState();

    try {
      activeController.reset(activeTaskContext);

      taskState.status = "started";
      taskState.answer = null;
      taskState.points = 0;
      taskState.lastModified = new Date().toISOString();

      persistState();
      hideFeedback();
      updateInterfaceWithoutRerender();
    } catch (error) {
      console.error(
        "Die Aufgabe konnte nicht zurückgesetzt werden.",
        error
      );

      showFeedback({
        type: "error",
        title: "Zurücksetzen nicht möglich",
        message:
          "Beim Zurücksetzen der Aufgabe ist ein technischer Fehler aufgetreten."
      });
    }
  }

  /* =========================================================
     27. HILFESTELLUNG
     ========================================================= */

  function handleHintRequest() {
    const task = getCurrentTask();
    const taskState = getCurrentTaskState();

    let hintText = null;

    if (
      activeController &&
      typeof activeController.getHint === "function"
    ) {
      try {
        hintText = activeController.getHint(
          activeTaskContext,
          taskState.usedHints
        );
      } catch (error) {
        console.warn(
          "Der Hinweis konnte nicht abgerufen werden.",
          error
        );
      }
    }

    if (
      !hintText &&
      Array.isArray(task.helpLevels) &&
      task.helpLevels.length > 0
    ) {
      const hintIndex = Math.min(
        taskState.usedHints,
        task.helpLevels.length - 1
      );

      hintText = task.helpLevels[hintIndex];
    }

    if (!hintText) {
      return;
    }

    taskState.usedHints += 1;
    taskState.lastModified = new Date().toISOString();

    persistState();
    updateTaskControls();

    showFeedback({
      type: "info",
      title: `Hinweis ${taskState.usedHints}`,
      message: hintText
    });
  }

  /* =========================================================
     28. CHEMIE-HILFE
     ========================================================= */

  function openChemistryHelp() {
    if (
      ui.chemistryHelpDialog &&
      typeof ui.chemistryHelpDialog.showModal === "function"
    ) {
      ui.chemistryHelpDialog.showModal();
    }
  }

  function closeChemistryHelp() {
    if (
      ui.chemistryHelpDialog &&
      ui.chemistryHelpDialog.open
    ) {
      ui.chemistryHelpDialog.close();
    }
  }

  /* =========================================================
     29. CONTROLLER REGISTRIEREN

     Spätere Codeabschnitte können einen Controller entweder
     für eine bestimmte Aufgabe oder für einen Aufgabentyp
     registrieren.
     ========================================================= */

  function registerTaskController(taskId, controller) {
    if (
      !TASKS_BY_ID.has(taskId) ||
      !isPlainObject(controller)
    ) {
      throw new Error(
        `Ungültiger Aufgaben-Controller: ${taskId}`
      );
    }

    TASK_CONTROLLERS_BY_ID.set(taskId, controller);

    if (appState.currentTaskId === taskId) {
      renderCurrentTask();
    }
  }

  function registerTaskTypeController(
    taskType,
    controller
  ) {
    if (
      typeof taskType !== "string" ||
      taskType.trim() === "" ||
      !isPlainObject(controller)
    ) {
      throw new Error(
        `Ungültiger Controller für Aufgabentyp: ${taskType}`
      );
    }

    TASK_CONTROLLERS_BY_TYPE.set(
      taskType,
      controller
    );

    const currentTask = getCurrentTask();

    if (currentTask.type === taskType) {
      renderCurrentTask();
    }
  }

  /* =========================================================
     30. ÖFFENTLICHE SCHNITTSTELLE

     Die folgenden Abschnitte greifen über window.EnzymeApp
     auf den Anwendungszustand und die Navigation zu.
     ========================================================= */

  window.EnzymeApp = {
    version: APP_VERSION,

    modules: cloneData(MODULES),
    tasks: cloneData(TASKS),

    getState() {
      return cloneData(appState);
    },

    getCurrentTask() {
      return cloneData(getCurrentTask());
    },

    getTaskState(taskId = appState.currentTaskId) {
      const taskState = appState.tasks[taskId];

      return taskState
        ? cloneData(taskState)
        : null;
    },

    registerTaskController,
    registerTaskTypeController,

    updateTaskState,
    setTaskAnswer,
    completeSelfCheck,

    goToTask,
    goToNextTask,
    goToPreviousTask,
    goToModule,

    showFeedback,
    hideFeedback,

    save() {
      return persistState({
        announce: true
      });
    },

    refresh() {
      renderCurrentTask();
    },

    refreshControls() {
      updateTaskControls();
    }
  };

  /* =========================================================
     31. EREIGNISSE VERKNÜPFEN
     ========================================================= */

  function bindInterfaceEvents() {
    ui.chemistryHelpButton.addEventListener(
      "click",
      openChemistryHelp
    );

    ui.chemistryHelpCloseIcon.addEventListener(
      "click",
      closeChemistryHelp
    );

    ui.chemistryHelpCloseButton.addEventListener(
      "click",
      closeChemistryHelp
    );

    ui.chemistryHelpDialog.addEventListener(
      "click",
      (event) => {
        if (event.target === ui.chemistryHelpDialog) {
          closeChemistryHelp();
        }
      }
    );

    ui.saveProgressButton.addEventListener(
      "click",
      () => {
        persistState({
          announce: true
        });
      }
    );

    ui.previousTaskButton.addEventListener(
      "click",
      goToPreviousTask
    );

    ui.nextTaskButton.addEventListener(
      "click",
      goToNextTask
    );

    ui.checkTaskButton.addEventListener(
      "click",
      handleCheckTask
    );

    ui.resetTaskButton.addEventListener(
      "click",
      handleResetTask
    );

    ui.hintButton.addEventListener(
      "click",
      handleHintRequest
    );

    for (const button of ui.moduleButtons) {
      button.addEventListener("click", () => {
        goToModule(button.dataset.moduleId);
      });
    }

    window.addEventListener(
      "beforeunload",
      () => {
        persistState();
      }
    );
  }

  /* =========================================================
     32. INITIALISIERUNG
     ========================================================= */

  function initializeApplication() {
    bindInterfaceEvents();

    ui.saveProgressButton.disabled = false;
    ui.saveProgressButton.removeAttribute(
      "aria-disabled"
    );
    ui.saveProgressButton.removeAttribute("title");

    ui.appVersion.textContent =
      `Version ${APP_VERSION}`;

    /*
      Sicherheitskorrektur für beschädigte oder manuell
      veränderte Speicherstände.
    */
    const currentTask = getCurrentTask();

    appState.highestUnlockedTask = Math.max(
      appState.highestUnlockedTask,
      currentTask.number
    );

    renderCurrentTask();

    console.info(
      `Enzymhemmung-Anwendung geladen: ${APP_VERSION}`
    );
  }

  /* =========================================================
     EINFÜGEPUNKT FÜR ABSCHNITT 3

     Die Controller für die wiederverwendbaren Aufgabentypen
     werden später unmittelbar VOR initializeApplication()
     eingefügt.
     ========================================================= */

  initializeApplication();
</script>
</body>
</html>
