  /* =========================================================
     8. ANFANGSZUSTAND
     ========================================================= */

  function createInitialTaskState(task) {
    return {
      taskId: task.id,
      status: "unseen",
      answer: null,
      attempts: 0,
      usedHints: 0,
      points: 0,
      maxPoints: task.maxPoints,
      lastModified: null
    };
  }

  function createInitialState() {
    const taskStates = {};

    for (const task of TASKS) {
      taskStates[task.id] = createInitialTaskState(task);
    }

    return {
      schemaVersion: STATE_SCHEMA_VERSION,
      appVersion: APP_VERSION,
      currentTaskId: TASKS[0].id,
      highestUnlockedTask: 1,

      startedAt: new Date().toISOString(),
      lastOpenedAt: new Date().toISOString(),
      lastSavedAt: null,

      lastTaskByModule: {
        "module-01": "task-01"
      },

      tasks: taskStates,

      settings: {
        chemistryHelpEnabled: false,
        reducedMotion:
          window.matchMedia("(prefers-reduced-motion: reduce)").matches,
        fontSize: "normal"
      }
    };
  }

  /* =========================================================
     9. SPEICHERSTAND VALIDIEREN UND ZUSAMMENFÜHREN
     ========================================================= */

  function isPlainObject(value) {
    return (
      typeof value === "object" &&
      value !== null &&
      !Array.isArray(value)
    );
  }

  function normalizeTaskState(savedTaskState, task) {
    const initialTaskState = createInitialTaskState(task);

    if (!isPlainObject(savedTaskState)) {
      return initialTaskState;
    }

    const status = VALID_TASK_STATUSES.has(savedTaskState.status)
      ? savedTaskState.status
      : initialTaskState.status;

    const attempts = Number.isInteger(savedTaskState.attempts)
      ? Math.max(0, savedTaskState.attempts)
      : 0;

    const usedHints = Number.isInteger(savedTaskState.usedHints)
      ? Math.max(0, savedTaskState.usedHints)
      : 0;

    const points = Number.isFinite(savedTaskState.points)
      ? Math.max(
          0,
          Math.min(task.maxPoints, savedTaskState.points)
        )
      : 0;

    return {
      taskId: task.id,
      status,
      answer:
        savedTaskState.answer === undefined
          ? null
          : savedTaskState.answer,
      attempts,
      usedHints,
      points,
      maxPoints: task.maxPoints,
      lastModified:
        typeof savedTaskState.lastModified === "string"
          ? savedTaskState.lastModified
          : null
    };
  }

  function mergeSavedState(savedState) {
    const freshState = createInitialState();

    if (
      !isPlainObject(savedState) ||
      savedState.schemaVersion !== STATE_SCHEMA_VERSION
    ) {
      return freshState;
    }

    const mergedTasks = {};

    for (const task of TASKS) {
      mergedTasks[task.id] = normalizeTaskState(
        savedState.tasks?.[task.id],
        task
      );
    }

    const savedCurrentTask =
      typeof savedState.currentTaskId === "string" &&
      TASKS_BY_ID.has(savedState.currentTaskId)
        ? savedState.currentTaskId
        : freshState.currentTaskId;

    const currentTaskNumber =
      TASKS_BY_ID.get(savedCurrentTask).number;

    const savedHighestUnlocked =
      Number.isInteger(savedState.highestUnlockedTask)
        ? savedState.highestUnlockedTask
        : 1;

    const highestUnlockedTask = Math.max(
      1,
      Math.min(
        TASKS.length,
        Math.max(savedHighestUnlocked, currentTaskNumber)
      )
    );

    const lastTaskByModule = {};

    if (isPlainObject(savedState.lastTaskByModule)) {
      for (const module of MODULES) {
        const candidate =
          savedState.lastTaskByModule[module.id];

        if (
          typeof candidate === "string" &&
          TASKS_BY_ID.has(candidate) &&
          TASKS_BY_ID.get(candidate).moduleId === module.id
        ) {
          lastTaskByModule[module.id] = candidate;
        }
      }
    }

    return {
      ...freshState,

      currentTaskId: savedCurrentTask,
      highestUnlockedTask,

      startedAt:
        typeof savedState.startedAt === "string"
          ? savedState.startedAt
          : freshState.startedAt,

      lastOpenedAt: new Date().toISOString(),

      lastSavedAt:
        typeof savedState.lastSavedAt === "string"
          ? savedState.lastSavedAt
          : null,

      lastTaskByModule,
      tasks: mergedTasks,

      settings: {
        ...freshState.settings,
        ...(isPlainObject(savedState.settings)
          ? savedState.settings
          : {})
      }
    };
  }

  /* =========================================================
     10. LOCALSTORAGE
     ========================================================= */

  function loadState() {
    try {
      const serializedState =
        window.localStorage.getItem(STORAGE_KEY);

      if (!serializedState) {
        return createInitialState();
      }

      const parsedState = JSON.parse(serializedState);
      return mergeSavedState(parsedState);
    } catch (error) {
      console.warn(
        "Der gespeicherte Bearbeitungsstand konnte nicht geladen werden.",
        error
      );

      return createInitialState();
    }
  }

  let appState = loadState();

  function persistState({ announce = false } = {}) {
    appState.appVersion = APP_VERSION;
    appState.lastSavedAt = new Date().toISOString();

    try {
      window.localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify(appState)
      );

      if (announce) {
        showFeedback({
          type: "success",
          title: "Bearbeitungsstand gespeichert",
          message:
            "Der aktuelle Stand wurde lokal in diesem Browser gespeichert.",
          autoHide: true
        });
      }

      return true;
    } catch (error) {
      console.error(
        "Der Bearbeitungsstand konnte nicht gespeichert werden.",
        error
      );

      if (announce) {
        showFeedback({
          type: "error",
          title: "Speichern nicht möglich",
          message:
            "Der Browser hat das lokale Speichern verhindert. Die Anwendung kann trotzdem weiterbearbeitet werden."
        });
      }

      return false;
    }
  }

  /* =========================================================
     11. ALLGEMEINE HILFSFUNKTIONEN
     ========================================================= */

  function cloneData(value) {
    return JSON.parse(JSON.stringify(value));
  }

  function clamp(value, minimum, maximum) {
    return Math.min(maximum, Math.max(minimum, value));
  }

  function getCurrentTask() {
    return TASKS_BY_ID.get(appState.currentTaskId);
  }

  function getCurrentTaskState() {
    return appState.tasks[appState.currentTaskId];
  }

  function getModuleForTask(task) {
    return MODULES_BY_ID.get(task.moduleId);
  }

  function getTaskByNumber(taskNumber) {
    return TASKS_BY_NUMBER.get(taskNumber) ?? null;
  }

  function getTaskController(task) {
    return (
      TASK_CONTROLLERS_BY_ID.get(task.id) ??
      TASK_CONTROLLERS_BY_TYPE.get(task.type) ??
      null
    );
  }

  function getTasksForModule(moduleId) {
    return TASKS.filter(
      (task) => task.moduleId === moduleId
    );
  }

  function isTaskCompleted(taskState) {
    return COMPLETED_TASK_STATUSES.has(taskState.status);
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function formatAttemptText(taskState) {
    const attemptPart =
      taskState.attempts === 0
        ? "Noch kein Prüfversuch"
        : taskState.attempts === 1
          ? "1 Prüfversuch"
          : `${taskState.attempts} Prüfversuche`;

    if (taskState.usedHints === 0) {
      return attemptPart;
    }

    const hintPart =
      taskState.usedHints === 1
        ? "1 Hinweis verwendet"
        : `${taskState.usedHints} Hinweise verwendet`;

    return `${attemptPart} · ${hintPart}`;
  }

