  /* =========================================================
     13. AUFGABENSTATUS AKTUALISIEREN
     ========================================================= */

  function markTaskStarted(taskId) {
    const taskState = appState.tasks[taskId];

    if (!taskState) {
      return;
    }

    if (taskState.status === "unseen") {
      taskState.status = "started";
      taskState.lastModified = new Date().toISOString();
    }
  }

  function updateTaskState(
    taskId,
    patch,
    {
      save = true,
      refresh = true
    } = {}
  ) {
    const task = TASKS_BY_ID.get(taskId);
    const taskState = appState.tasks[taskId];

    if (!task || !taskState || !isPlainObject(patch)) {
      return false;
    }

    if (
      patch.status !== undefined &&
      VALID_TASK_STATUSES.has(patch.status)
    ) {
      taskState.status = patch.status;
    }

    if (patch.answer !== undefined) {
      taskState.answer = patch.answer;
    }

    if (
      patch.attempts !== undefined &&
      Number.isInteger(patch.attempts)
    ) {
      taskState.attempts = Math.max(0, patch.attempts);
    }

    if (
      patch.usedHints !== undefined &&
      Number.isInteger(patch.usedHints)
    ) {
      taskState.usedHints = Math.max(
        0,
        patch.usedHints
      );
    }

    if (
      patch.points !== undefined &&
      Number.isFinite(patch.points)
    ) {
      taskState.points = clamp(
        patch.points,
        0,
        task.maxPoints
      );
    }

    taskState.lastModified = new Date().toISOString();

    if (save) {
      persistState();
    }

    if (refresh) {
      updateInterfaceWithoutRerender();
    }

    return true;
  }

  function setTaskAnswer(taskId, answer) {
    return updateTaskState(
      taskId,
      { answer },
      {
        save: true,
        refresh: false
      }
    );
  }

  function completeSelfCheck(taskId, answer = undefined) {
    const patch = {
      status: "completed-self-check"
    };

    if (answer !== undefined) {
      patch.answer = answer;
    }

    updateTaskState(taskId, patch);
  }

  /* =========================================================
     14. FORTSCHRITT
     ========================================================= */

  function calculateProgress() {
    const completedTasks = TASKS.filter((task) =>
      isTaskCompleted(appState.tasks[task.id])
    ).length;

    const percentage = Math.round(
      (completedTasks / TASKS.length) * 100
    );

    return {
      completedTasks,
      totalTasks: TASKS.length,
      percentage
    };
  }

  function updateProgressDisplay() {
    const currentTask = getCurrentTask();
    const currentModule = getModuleForTask(currentTask);
    const progress = calculateProgress();

    ui.progressLabel.textContent =
      `Modul ${currentModule.number} von ${MODULES.length}` +
      ` · Aufgabe ${currentTask.number} von ${TASKS.length}`;

    ui.progressPercent.textContent =
      `${progress.percentage} %`;

    ui.progressBar.style.width =
      `${progress.percentage}%`;

    ui.overallProgress.setAttribute(
      "aria-valuenow",
      String(progress.percentage)
    );

    ui.overallProgress.setAttribute(
      "aria-valuetext",
      `${progress.completedTasks} von ${progress.totalTasks} Aufgaben abgeschlossen`
    );
  }

  /* =========================================================
     15. MODULSTATUS
     ========================================================= */

  function calculateModuleStatus(moduleId) {
    const moduleTasks = getTasksForModule(moduleId);
    const moduleTaskStates = moduleTasks.map(
      (task) => appState.tasks[task.id]
    );

    const allCompleted = moduleTaskStates.every(
      isTaskCompleted
    );

    if (allCompleted) {
      return {
        symbol: "✓",
        label: "Modul vollständig abgeschlossen"
      };
    }

    const hasPartial = moduleTaskStates.some(
      (taskState) =>
        taskState.status === "checked-partial" ||
        taskState.status === "checked-incorrect"
    );

    if (hasPartial) {
      return {
        symbol: "△",
        label: "Modul teilweise bearbeitet"
      };
    }

    const hasStarted = moduleTaskStates.some(
      (taskState) => taskState.status !== "unseen"
    );

    if (hasStarted) {
      return {
        symbol: "◐",
        label: "Modul begonnen"
      };
    }

    return {
      symbol: "○",
      label: "Noch nicht bearbeitet"
    };
  }

  function updateModuleNavigation() {
    const currentTask = getCurrentTask();

    for (const button of ui.moduleButtons) {
      const moduleId = button.dataset.moduleId;
      const module = MODULES_BY_ID.get(moduleId);

      if (!module) {
        continue;
      }

      const status = calculateModuleStatus(moduleId);
      const statusElement =
        button.querySelector(".module-status");

      const isCurrentModule =
        currentTask.moduleId === moduleId;

      const isUnlocked =
        module.firstTask <= appState.highestUnlockedTask;

      button.disabled = !isUnlocked;

      if (isUnlocked) {
        button.removeAttribute("aria-disabled");
      } else {
        button.setAttribute("aria-disabled", "true");
      }

      if (isCurrentModule) {
        button.setAttribute("aria-current", "step");
      } else {
        button.removeAttribute("aria-current");
      }

      if (statusElement) {
        statusElement.textContent = status.symbol;
        statusElement.setAttribute(
          "aria-label",
          status.label
        );
      }
    }
  }

