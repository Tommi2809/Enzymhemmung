<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <meta
    name="description"
    content="Interaktive Lernanwendung zur Enzymhemmung durch Allopurinol"
  >

  <title>Enzymhemmung – Allopurinol bei Gicht</title>

  <style>
    /* =========================================================
       1. GRUNDEINSTELLUNGEN
       ========================================================= */

    :root {
      color-scheme: light;

      --color-page: #f3f6f8;
      --color-surface: #ffffff;
      --color-surface-muted: #edf3f6;
      --color-surface-strong: #dfe9ed;

      --color-text: #16242b;
      --color-text-muted: #52646d;
      --color-border: #c8d5da;
      --color-border-strong: #9eb0b8;

      --color-primary: #176b75;
      --color-primary-dark: #10515a;
      --color-primary-light: #d9eef0;

      --color-accent: #875d0a;
      --color-accent-light: #fff1c9;

      --color-success: #17633b;
      --color-success-light: #e0f3e8;

      --color-warning: #7a4d00;
      --color-warning-light: #fff0cf;

      --color-error: #a12a2a;
      --color-error-light: #fbe5e5;

      --color-info: #205a8c;
      --color-info-light: #e3f0fa;

      --shadow-small:
        0 1px 2px rgba(20, 40, 48, 0.08),
        0 3px 8px rgba(20, 40, 48, 0.05);

      --shadow-medium:
        0 4px 14px rgba(20, 40, 48, 0.09);

      --radius-small: 0.45rem;
      --radius-medium: 0.75rem;
      --radius-large: 1rem;

      --content-width: 1500px;
      --sidebar-width: 19rem;

      --transition-fast: 140ms ease;
      --transition-normal: 220ms ease;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html {
      min-height: 100%;
      scroll-behavior: smooth;
    }

    body {
      min-height: 100%;
      margin: 0;
      background: var(--color-page);
      color: var(--color-text);
      font-family:
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        sans-serif;
      font-size: 1rem;
      line-height: 1.55;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    button {
      touch-action: manipulation;
    }

    img,
    svg {
      display: block;
      max-width: 100%;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1,
    h2,
    h3 {
      line-height: 1.25;
    }

    h1 {
      font-size: clamp(1.55rem, 2vw, 2.15rem);
    }

    h2 {
      font-size: 1.25rem;
    }

    a {
      color: var(--color-primary-dark);
    }

    button:focus-visible,
    a:focus-visible,
    input:focus-visible,
    select:focus-visible,
    textarea:focus-visible,
    [tabindex]:focus-visible {
      outline: 3px solid #f0a400;
      outline-offset: 3px;
    }

    [hidden] {
      display: none !important;
    }

    .visually-hidden {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }

    /* =========================================================
       2. SPRUNGLINK
       ========================================================= */

    .skip-link {
      position: fixed;
      top: 0.75rem;
      left: 0.75rem;
      z-index: 1000;
      padding: 0.75rem 1rem;
      border-radius: var(--radius-small);
      background: var(--color-text);
      color: #ffffff;
      font-weight: 700;
      text-decoration: none;
      transform: translateY(-160%);
      transition: transform var(--transition-fast);
    }

    .skip-link:focus {
      transform: translateY(0);
    }

    /* =========================================================
       3. ANWENDUNGSRAHMEN
       ========================================================= */

    .app-shell {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--color-border);
      background: rgba(255, 255, 255, 0.97);
      box-shadow: var(--shadow-small);
      backdrop-filter: blur(8px);
    }

    .header-inner {
      width: min(100% - 2rem, var(--content-width));
      margin-inline: auto;
      padding-block: 1rem 0.85rem;
    }

    .header-main-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .brand {
      display: flex;
      align-items: center;
      min-width: 0;
      gap: 0.85rem;
    }

    .brand-symbol {
      flex: 0 0 auto;
      width: 3rem;
      height: 3rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--color-primary);
      color: #ffffff;
      font-size: 1.35rem;
      font-weight: 800;
      letter-spacing: -0.06em;
    }

    .brand-copy {
      min-width: 0;
    }

    .brand-title {
      margin: 0;
      color: var(--color-text);
      font-size: clamp(1.05rem, 2vw, 1.4rem);
      font-weight: 800;
    }

    .brand-subtitle {
      margin: 0.1rem 0 0;
      color: var(--color-text-muted);
      font-size: 0.9rem;
    }

    .header-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.6rem;
    }

    /* =========================================================
       4. FORTSCHRITTSANZEIGE
       ========================================================= */

    .progress-section {
      margin-top: 0.9rem;
    }

    .progress-copy {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.35rem;
      color: var(--color-text-muted);
      font-size: 0.9rem;
    }

    .progress-copy strong {
      color: var(--color-text);
    }

    .progress-track {
      height: 0.7rem;
      overflow: hidden;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: var(--color-surface-muted);
    }

    .progress-fill {
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: var(--color-primary);
      transition: width var(--transition-normal);
    }

    /* =========================================================
       5. HAUPTLAYOUT
       ========================================================= */

    .app-layout {
      width: min(100% - 2rem, var(--content-width));
      flex: 1;
      display: grid;
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      align-items: start;
      gap: 1.5rem;
      margin-inline: auto;
      padding-block: 1.5rem 2.5rem;
    }

    .sidebar {
      position: sticky;
      top: 8.5rem;
      overflow: hidden;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-large);
      background: var(--color-surface);
      box-shadow: var(--shadow-small);
    }

    .sidebar-header {
      padding: 1.1rem 1.1rem 0.9rem;
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar-header h2 {
      margin-bottom: 0.25rem;
    }

    .sidebar-header p {
      margin-bottom: 0;
      color: var(--color-text-muted);
      font-size: 0.9rem;
    }

    .main-content {
      min-width: 0;
    }

    /* =========================================================
       6. MODULNAVIGATION
       ========================================================= */

    .module-list {
      list-style: none;
      padding: 0.75rem;
      margin: 0;
    }

    .module-list li + li {
      margin-top: 0.35rem;
    }

    .module-button {
      width: 100%;
      min-height: 3.35rem;
      display: grid;
      grid-template-columns: 2.2rem minmax(0, 1fr) 1.25rem;
      align-items: center;
      gap: 0.65rem;
      padding: 0.65rem 0.75rem;
      border: 1px solid transparent;
      border-radius: var(--radius-medium);
      background: transparent;
      color: var(--color-text);
      text-align: left;
      cursor: pointer;
      transition:
        background var(--transition-fast),
        border-color var(--transition-fast);
    }

    .module-button:hover {
      background: var(--color-surface-muted);
    }

    .module-button[aria-current="step"] {
      border-color: var(--color-primary);
      background: var(--color-primary-light);
    }

    .module-index {
      width: 2.1rem;
      height: 2.1rem;
      display: grid;
      place-items: center;
      border: 1px solid var(--color-border-strong);
      border-radius: 50%;
      background: var(--color-surface);
      font-size: 0.85rem;
      font-weight: 800;
    }

    .module-button[aria-current="step"] .module-index {
      border-color: var(--color-primary);
      background: var(--color-primary);
      color: #ffffff;
    }

    .module-copy {
      min-width: 0;
    }

    .module-name {
      display: block;
      font-weight: 750;
    }

    .module-task-count {
      display: block;
      margin-top: 0.05rem;
      color: var(--color-text-muted);
      font-size: 0.78rem;
    }

    .module-status {
      display: grid;
      place-items: center;
      color: var(--color-text-muted);
      font-size: 1rem;
      font-weight: 800;
    }

    .status-legend {
      padding: 0.85rem 1.1rem 1rem;
      border-top: 1px solid var(--color-border);
      background: var(--color-surface-muted);
    }

    .status-legend h3 {
      margin-bottom: 0.55rem;
      font-size: 0.9rem;
    }

    .status-legend-list {
      list-style: none;
      display: grid;
      gap: 0.3rem;
      padding: 0;
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.8rem;
    }

    .status-symbol {
      display: inline-block;
      width: 1.3rem;
      color: var(--color-text);
      font-weight: 800;
    }

    /* =========================================================
       7. AUFGABENKARTE
       ========================================================= */

    .task-card {
      overflow: hidden;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-large);
      background: var(--color-surface);
      box-shadow: var(--shadow-medium);
    }

    .task-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.25rem;
      padding: 1.4rem 1.5rem 1.2rem;
      border-bottom: 1px solid var(--color-border);
      background:
        linear-gradient(
          135deg,
          var(--color-primary-light),
          #ffffff 70%
        );
    }

    .task-header-copy {
      min-width: 0;
    }

    .eyebrow {
      margin-bottom: 0.25rem;
      color: var(--color-primary-dark);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .task-header h1 {
      margin-bottom: 0;
    }

    .task-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.45rem;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 1.85rem;
      padding: 0.25rem 0.65rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: var(--color-surface);
      color: var(--color-text-muted);
      font-size: 0.78rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge--automatic {
      border-color: #a9cbd0;
      background: var(--color-primary-light);
      color: var(--color-primary-dark);
    }

    .task-body {
      padding: 1.5rem;
    }

    .task-instruction {
      max-width: 78ch;
      margin-bottom: 1.25rem;
      color: var(--color-text);
      font-size: 1.04rem;
    }

    .task-instruction strong {
      font-weight: 800;
    }

    .task-workspace {
      min-height: 17rem;
      display: grid;
      place-items: center;
      padding: 1.25rem;
      border: 2px dashed var(--color-border);
      border-radius: var(--radius-medium);
      background: var(--color-surface-muted);
    }

    .workspace-placeholder {
      max-width: 42rem;
      text-align: center;
    }

    .workspace-placeholder-icon {
      width: 4.2rem;
      height: 4.2rem;
      display: grid;
      place-items: center;
      margin: 0 auto 1rem;
      border-radius: 50%;
      background: var(--color-primary-light);
      color: var(--color-primary-dark);
      font-size: 1.7rem;
      font-weight: 900;
    }

    .workspace-placeholder h2 {
      margin-bottom: 0.5rem;
    }

    .workspace-placeholder p {
      margin-bottom: 0;
      color: var(--color-text-muted);
    }

    /* =========================================================
       8. AUFGABENWERKZEUGE
       ========================================================= */

    .task-tools {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.65rem;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--color-border);
      background: #fafcfd;
    }

    .tool-note {
      margin-left: auto;
      color: var(--color-text-muted);
      font-size: 0.85rem;
    }

    /* =========================================================
       9. FEEDBACKBEREICH
       ========================================================= */

    .feedback {
      margin: 0 1.5rem 1.2rem;
      padding: 1rem 1.1rem;
      border: 1px solid var(--color-border);
      border-left-width: 0.4rem;
      border-radius: var(--radius-medium);
      background: var(--color-info-light);
    }

    .feedback h2 {
      margin-bottom: 0.35rem;
      font-size: 1rem;
    }

    .feedback p:last-child {
      margin-bottom: 0;
    }

    .feedback--success {
      border-color: var(--color-success);
      background: var(--color-success-light);
    }

    .feedback--warning {
      border-color: var(--color-warning);
      background: var(--color-warning-light);
    }

    .feedback--error {
      border-color: var(--color-error);
      background: var(--color-error-light);
    }

    .feedback--info {
      border-color: var(--color-info);
      background: var(--color-info-light);
    }

    /* =========================================================
       10. AUFGABENNAVIGATION
       ========================================================= */

    .task-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--color-border);
      background: var(--color-surface-muted);
    }

    .task-actions-left,
    .task-actions-right {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    /* =========================================================
       11. SCHALTFLÄCHEN
       ========================================================= */

    .button {
      min-height: 2.75rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      padding: 0.62rem 0.95rem;
      border: 1px solid transparent;
      border-radius: var(--radius-small);
      font-weight: 750;
      line-height: 1.2;
      cursor: pointer;
      transition:
        background var(--transition-fast),
        border-color var(--transition-fast),
        color var(--transition-fast),
        transform var(--transition-fast);
    }

    .button:hover:not(:disabled) {
      transform: translateY(-1px);
    }

    .button:active:not(:disabled) {
      transform: translateY(0);
    }

    .button:disabled,
    .button[aria-disabled="true"] {
      cursor: not-allowed;
      opacity: 0.52;
    }

    .button--primary {
      border-color: var(--color-primary);
      background: var(--color-primary);
      color: #ffffff;
    }

    .button--primary:hover:not(:disabled) {
      border-color: var(--color-primary-dark);
      background: var(--color-primary-dark);
    }

    .button--secondary {
      border-color: var(--color-border-strong);
      background: var(--color-surface);
      color: var(--color-text);
    }

    .button--secondary:hover:not(:disabled) {
      border-color: var(--color-primary);
      background: var(--color-primary-light);
    }

    .button--ghost {
      border-color: transparent;
      background: transparent;
      color: var(--color-primary-dark);
    }

    .button--ghost:hover:not(:disabled) {
      background: var(--color-primary-light);
    }

    .button-icon {
      font-size: 1.05em;
      line-height: 1;
    }

    /* =========================================================
       12. ZUSATZHINWEISE
       ========================================================= */

    .information-card {
      margin-top: 1.25rem;
      padding: 1.2rem 1.35rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-large);
      background: var(--color-surface);
      box-shadow: var(--shadow-small);
    }

    .information-card h2 {
      margin-bottom: 0.75rem;
    }

    .information-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .information-item {
      padding: 0.9rem;
      border-radius: var(--radius-medium);
      background: var(--color-surface-muted);
    }

    .information-item strong {
      display: block;
      margin-bottom: 0.2rem;
    }

    .information-item p {
      margin-bottom: 0;
      color: var(--color-text-muted);
      font-size: 0.9rem;
    }

    /* =========================================================
       13. DIALOGFENSTER
       ========================================================= */

    .app-dialog {
      width: min(92vw, 42rem);
      max-height: 85vh;
      padding: 0;
      overflow: auto;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-large);
      background: var(--color-surface);
      color: var(--color-text);
      box-shadow: 0 20px 60px rgba(10, 28, 35, 0.24);
    }

    .app-dialog::backdrop {
      background: rgba(12, 27, 34, 0.56);
    }

    .dialog-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      padding: 1.2rem 1.3rem;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-primary-light);
    }

    .dialog-header h2 {
      margin-bottom: 0;
    }

    .dialog-body {
      padding: 1.3rem;
    }

    .dialog-footer {
      display: flex;
      justify-content: flex-end;
      padding: 1rem 1.3rem;
      border-top: 1px solid var(--color-border);
      background: var(--color-surface-muted);
    }

    .dialog-close-icon {
      width: 2.6rem;
      height: 2.6rem;
      display: grid;
      place-items: center;
      padding: 0;
      border: 1px solid var(--color-border);
      border-radius: 50%;
      background: var(--color-surface);
      color: var(--color-text);
      font-size: 1.2rem;
      cursor: pointer;
    }

    /* =========================================================
       14. FUSSZEILE
       ========================================================= */

    .site-footer {
      border-top: 1px solid var(--color-border);
      background: var(--color-surface);
    }

    .site-footer-inner {
      width: min(100% - 2rem, var(--content-width));
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 0.75rem;
      margin-inline: auto;
      padding-block: 1rem;
      color: var(--color-text-muted);
      font-size: 0.82rem;
    }

    /* =========================================================
       15. RESPONSIVES LAYOUT
       ========================================================= */

    @media (max-width: 1100px) {
      .app-layout {
        grid-template-columns: 15.5rem minmax(0, 1fr);
      }

      .module-button {
        grid-template-columns: 2rem minmax(0, 1fr);
      }

      .module-status {
        display: none;
      }

      .information-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 820px) {
      .site-header {
        position: static;
      }

      .header-main-row {
        align-items: flex-start;
        flex-direction: column;
      }

      .header-actions {
        width: 100%;
        justify-content: flex-start;
      }

      .app-layout {
        grid-template-columns: 1fr;
        padding-top: 1rem;
      }

      .sidebar {
        position: static;
      }

      .module-list {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        scroll-snap-type: x proximity;
      }

      .module-list li {
        flex: 0 0 min(17rem, 82vw);
        scroll-snap-align: start;
      }

      .module-list li + li {
        margin-top: 0;
      }

      .status-legend {
        display: none;
      }

      .task-header {
        flex-direction: column;
      }

      .task-badges {
        justify-content: flex-start;
      }
    }

    @media (max-width: 620px) {
      .header-inner,
      .app-layout,
      .site-footer-inner {
        width: min(100% - 1rem, var(--content-width));
      }

      .brand-symbol {
        width: 2.65rem;
        height: 2.65rem;
      }

      .brand-subtitle {
        display: none;
      }

      .header-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .header-actions .button {
        width: 100%;
      }

      .task-header,
      .task-body,
      .task-tools,
      .task-footer {
        padding-inline: 1rem;
      }

      .feedback {
        margin-inline: 1rem;
      }

      .task-footer {
        align-items: stretch;
        flex-direction: column;
      }

      .task-actions-left,
      .task-actions-right {
        display: grid;
        grid-template-columns: 1fr;
      }

      .task-footer .button {
        width: 100%;
      }

      .tool-note {
        width: 100%;
        margin-left: 0;
      }
    }

    @media (max-width: 420px) {
      .header-actions {
        grid-template-columns: 1fr;
      }

      .task-workspace {
        min-height: 14rem;
        padding: 0.9rem;
      }
    }

    /* =========================================================
       16. REDUZIERTE BEWEGUNG
       ========================================================= */

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      *,
      *::before,
      *::after {
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
      }
    }

    /* =========================================================
       17. DRUCKANSICHT
       ========================================================= */

    @media print {
      .site-header,
      .sidebar,
      .task-tools,
      .task-footer,
      .site-footer,
      .information-card {
        display: none !important;
      }

      body {
        background: #ffffff;
      }

      .app-layout {
        display: block;
        width: 100%;
        padding: 0;
      }

      .task-card {
        border: 0;
        box-shadow: none;
      }
